---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import Card from "@/components/temple/Card.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import { GITHUB_CONFIG, SITE_PAGES, USER_AVATAR, USER_DESCRIPTION, USER_NAME, USER_SIDEBAR_SOCIAL_ICONS, USER_SITE } from "@config";
import { SITE_NARRATIVE, SITE_PILLARS } from "@/data/siteNarrative";
import { getAllPosts } from "@utils/blogUtils";

const aboutPage = SITE_PAGES.about || {};
const aboutLead = aboutPage.leadParagraphs || SITE_NARRATIVE.aboutLead;
const aboutWorkflow = aboutPage.workflowSteps || SITE_NARRATIVE.aboutWorkflow;
const aboutPillars = aboutPage.pillars || SITE_PILLARS;
const posts = await getAllPosts();
const pinnedPosts = posts.filter(post => post.data.badge === "Pin").slice(0, 3);
const postCount = posts.length;
const pinnedCount = pinnedPosts.length;
const categoryCount = new Set(posts.flatMap(post => post.data.categories || [])).size;
const tagCount = new Set(posts.flatMap(post => post.data.tags || [])).size;
const socialLinks = (USER_SIDEBAR_SOCIAL_ICONS || []).slice(0, 4);
const githubUsername = GITHUB_CONFIG?.owner || "kobaridev";
---

<BaseLayout title={aboutPage.title || "About"} isIndexed={false}>
  <div class="space-y-8">
    <Card class="overflow-hidden border border-primary/10 bg-gradient-to-br from-primary/5 via-base-100 to-secondary/5 p-6 md:p-8">
      <div class="flex flex-col gap-8 md:flex-row md:items-start">
        <div class="shrink-0">
          <div class="w-28 h-28 md:w-36 md:h-36 rounded-[1.75rem] overflow-hidden ring ring-primary/30 ring-offset-base-100 ring-offset-4 shadow-xl">
            <img src={USER_AVATAR} alt={USER_NAME} class="w-full h-full object-cover" width="144" height="144" loading="eager" />
          </div>
        </div>

        <div class="flex-1 space-y-5">
          <div class="space-y-2">
            <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
              <Icon name="lucide:circle-user-round" class="w-4 h-4" />
              <span>{aboutPage.subtitle || "关于这个博客"}</span>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold">{USER_NAME}</h1>
            <p class="text-lg text-base-content/70">{USER_DESCRIPTION}</p>
          </div>

          <div class="space-y-3 text-base-content/75 leading-relaxed">
            {aboutLead.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          <div class="flex flex-wrap gap-3">
            {socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-sm btn-outline gap-2 rounded-full"
              >
                <Icon name={link.svg} class="w-4 h-4" />
                <span>{link.title}</span>
              </a>
            ))}
            <a href={USER_SITE} target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-primary gap-2 rounded-full">
              <Icon name="lucide:globe" class="w-4 h-4" />
              <span>个人主页</span>
            </a>
          </div>
        </div>
      </div>
    </Card>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <Card class="p-5">
        <div class="text-sm text-base-content/50">已发布文章</div>
        <div class="mt-2 text-3xl font-bold">{postCount}</div>
      </Card>
      <Card class="p-5">
        <div class="text-sm text-base-content/50">置顶文章</div>
        <div class="mt-2 text-3xl font-bold">{pinnedCount}</div>
      </Card>
      <Card class="p-5">
        <div class="text-sm text-base-content/50">分类数量</div>
        <div class="mt-2 text-3xl font-bold">{categoryCount}</div>
      </Card>
      <Card class="p-5">
        <div class="text-sm text-base-content/50">标签数量</div>
        <div class="mt-2 text-3xl font-bold">{tagCount}</div>
      </Card>
    </div>

    <Card class="p-6 md:p-8">
      <div class="mb-6 flex items-center gap-3">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-primary/10 text-primary">
          <Icon name="lucide:layers-3" class="w-5 h-5" />
        </div>
        <div>
          <h2 class="text-2xl font-bold">当前关注主题</h2>
          <p class="text-base-content/60">首页、关于页和导航页会围绕同一套主题表达展开。</p>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {aboutPillars.map((pillar) => (
          <div class="rounded-[1.5rem] bg-base-200/40 p-5 ring-1 ring-base-200">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-primary/10 text-primary">
              <Icon name={pillar.icon} class="w-5 h-5" />
            </div>
            <h3 class="mb-2 text-lg font-semibold">{pillar.title}</h3>
            <p class="text-sm leading-relaxed text-base-content/65">{pillar.description}</p>
          </div>
        ))}
      </div>
    </Card>

    <div class="grid gap-6 lg:grid-cols-2">
      <Card class="p-6 md:p-8">
        <div class="mb-5 flex items-center gap-3">
          <Icon name="lucide:workflow" class="w-6 h-6 text-primary" />
          <h2 class="text-2xl font-bold">写作与维护方式</h2>
        </div>
        <div class="space-y-3">
          {aboutWorkflow.map((item, index) => (
            <div class="flex items-start gap-3 rounded-2xl bg-base-200/40 p-4">
              <div class="mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary text-primary-content text-sm font-bold">
                {index + 1}
              </div>
              <p class="text-sm leading-relaxed text-base-content/70">{item}</p>
            </div>
          ))}
        </div>
      </Card>

      <Card class="p-6 md:p-8">
        <div class="mb-5 flex items-center gap-3">
          <Icon name="lucide:book-marked" class="w-6 h-6 text-primary" />
          <h2 class="text-2xl font-bold">推荐起步阅读</h2>
        </div>
        <div class="space-y-3">
          {pinnedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="block rounded-2xl bg-base-200/40 p-4 transition-all hover:-translate-y-0.5 hover:bg-base-200/70">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <h3 class="font-semibold">{post.data.title}</h3>
                  <p class="mt-1 text-sm text-base-content/65">{post.data.description}</p>
                </div>
                <Icon name="lucide:arrow-up-right" class="w-5 h-5 text-primary shrink-0" />
              </div>
            </a>
          ))}
        </div>
      </Card>
    </div>

    <Card class="p-6 md:p-8">
      <div class="mb-6 flex items-center gap-3">
        <Icon name="lucide:github" class="w-6 h-6 text-primary" />
        <div>
          <h2 class="text-2xl font-bold">GitHub 概览</h2>
          <p class="text-base-content/60">站点内容维护之外，代码和仓库工作流也会在这里持续迭代。</p>
        </div>
      </div>
      <GitHubStats username={githubUsername} showLanguages={false} showCommitGraph={true} />
    </Card>
  </div>
</BaseLayout>
